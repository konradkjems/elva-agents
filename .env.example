# OpenAI API Key - Get from https://platform.openai.com/api-keys
# Still used by the legacy/openai-hosted (`pmpt_…`) chat paths.
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Vercel AI Gateway — used by the in-platform multi-provider chat engine (lib/ai).
# A single key routes "provider/model" strings (openai/anthropic/google/…) through
# the Gateway. Provider API keys (BYOK) are configured in the Gateway dashboard,
# not here — there is no per-token markup. Get the key from the Vercel dashboard
# → AI Gateway → API keys.
# ─────────────────────────────────────────────────────────────────────────────
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Firecrawl — hosted crawl/scrape used by "auto-create chatbot from website" and
# the RAG knowledge-base ingestion crawl (lib/crawl/firecrawl.js, lib/rag/*).
# RAG embeddings reuse AI_GATEWAY_API_KEY above (openai/text-embedding-3-small).
# Get a key at https://firecrawl.dev
# ─────────────────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-your_firecrawl_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (Database + Auth + Storage) — target platform
# Get these from Supabase dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service-role key — SERVER ONLY, never expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Direct Postgres connection string — used by migration scripts (scripts/supabase/*)
# Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB — LEGACY, removed after Phase 1 data migration completes
# Still required while running scripts/supabase/migrate-*.js (reads from Mongo)
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatwidgets?retryWrites=true&w=majority&authSource=admin
# For Local MongoDB (Development):
# MONGODB_URI=mongodb://localhost:27017/elva-agents

# Cloudinary Configuration — LEGACY, removed after Phase 3 storage migration
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Environment Configuration
NODE_ENV=production

# Production Configuration (for Vercel)
# NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
# NODE_ENV=production

GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=Elva Solutions <invitations@yourdomain.com>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Job Secret — Bearer token Vercel injects on scheduled cron invocations.
# Used by /api/cron/process-deletions, apply-retention, and process-knowledge
# (the RAG ingestion safety-net worker).
CRON_SECRET=your-secure-random-string